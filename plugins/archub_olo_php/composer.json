{
  "name": "archub/olo-plugin",
  "description": "ArcHub OurLifeOrganized (GTD task manager) external plugin powered by Symfony 8 and PHP 8.4.",
  "type": "project",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.4",
    "symfony/framework-bundle": "^8.0",
    "symfony/http-foundation": "^8.0",
    "symfony/routing": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/uid": "^8.0",
    "league/commonmark": "^2.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.70"
  },
  "autoload": {
    "psr-4": {
      "ArcHub\\OloPlugin\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8098 -t public",
    "lint": "php -l public/index.php && find src -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/runtime": true
    }
  }
}
