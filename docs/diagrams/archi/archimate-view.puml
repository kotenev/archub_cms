@startuml
!include <archimate/Archimate>
title ArcHub CMS - ArchiMate Layer View (Current DDD Architecture)

Business_Actor(editor, "Content editor")
Business_Actor(visitor, "Public visitor")
Business_Actor(runtimeConsumer, "Runtime/RAG consumer")
Business_Actor(pluginDev, "Plugin developer")
Business_Actor(agentClient, "Agent/LLM client")

Business_Service(backofficeService, "Backoffice service")
Business_Service(deliveryService, "Published delivery service")
Business_Service(knowledgeService, "Knowledge platform service")
Business_Service(collaborationService, "Collaboration service")

Application_Service(adminService, "Admin HTML dashboard")
Application_Service(platformAPIService, "Platform JSON API")
Application_Service(collabAPIService, "Collaboration JSON API")

Application_Component(routes, "Legacy FastAPI routes")
Application_Component(platformRoutes, "Platform routes")
Application_Component(collabRoutes, "Collaboration routes")
Application_Component(platform, "ArcHubPlatform composition root")
Application_Component(contentSvc, "Content service")
Application_Component(modelingSvc, "Modeling service")
Application_Component(deliverySvc, "Delivery read service")
Application_Component(publishingSvc, "Publishing service")
Application_Component(workflowSvc, "Workflow service")
Application_Component(governanceSvc, "Governance service")
Application_Component(agentSvc, "Agent service")
Application_Component(searchSvc, "Search + FTS5 service")
Application_Component(collabSvc, "Collaboration service")
Application_Component(pluginHost, "Plugin host")
Application_Component(pluginAdapter, "Plugin platform adapter")
Application_Component(pluginSqlRepos, "Plugin SQL repositories")
Application_Component(cmsLegacy, "ArcHubCMSService legacy")

Application_Interface(ports, "Host integration ports\nAuth, Template, Runtime, LLM,\nEmbedding, Search, Cache, Audit")

Technology_Node(process, "FastAPI process")
Technology_Artifact(templates, "Templates and static assets")
Application_DataObject(store, "SQLite CMS store")
Application_DataObject(snapshot, "Runtime snapshot files")
Application_DataObject(ftsIndex, "FTS5 full-text index")
Application_DataObject(pluginConfig, "Plugin config store")
Application_DataObject(pluginAudit, "Plugin audit log")
Application_DataObject(pluginData, "Plugin data store")

editor --> backofficeService : uses
visitor --> deliveryService : reads
agentClient --> knowledgeService : invokes
editor --> collaborationService : collaborates
routes --> adminService : exposes
routes --> deliveryService : exposes
platformRoutes --> platformAPIService : exposes
collabRoutes --> collabAPIService : exposes
process *-- routes : hosts
process *-- platformRoutes : hosts
process *-- collabRoutes : hosts
platform *-- contentSvc : composes
platform *-- modelingSvc : composes
platform *-- deliverySvc : composes
platform *-- publishingSvc : composes
platform *-- workflowSvc : composes
platform *-- governanceSvc : composes
platform *-- agentSvc : composes
platform *-- searchSvc : composes
platform *-- collabSvc : composes
platform *-- pluginHost : composes
pluginHost *-- pluginAdapter : provides context.platform
pluginAdapter *-- pluginSqlRepos : uses
cmsLegacy --> contentSvc : backs
cmsLegacy --> modelingSvc : backs
cmsLegacy --> deliverySvc : backs
ports --> platform : contracts
cmsLegacy --> store : reads/writes
searchSvc --> ftsIndex : indexes
routes --> templates : renders
deliverySvc --> snapshot : exports
runtimeConsumer --> snapshot : consumes
pluginDev --> pluginHost : develops plugins
pluginHost --> pluginConfig : manages config
pluginAdapter --> pluginAudit : records
pluginSqlRepos --> pluginData : persists
@enduml
